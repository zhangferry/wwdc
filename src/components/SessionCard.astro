---
import { formatDuration, levelLabel } from "../utils/format";

interface Props {
  id: string;
  title: string;
  titleZh: string;
  track: string;
  level: string;
  duration: number;
  thumbnail: string;
  date: Date;
}

const { id, title, titleZh, track, level, duration, thumbnail, date } = Astro.props;
const year = date.getFullYear();
const href = `/wwdc${year}/${id}`;
---

<a href={href} class="group block rounded-xl overflow-hidden transition-all duration-200 hover:shadow-lg" style="background-color: var(--color-surface); border: 1px solid var(--color-border-subtle);">
  <!-- Cover -->
  <div class="relative aspect-video overflow-hidden">
    <img
      src={thumbnail}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
    />
    {duration > 0 && (
      <span class="absolute bottom-2 right-2 px-2 py-0.5 rounded text-xs font-medium" style="background-color: rgba(0,0,0,0.7); color: white;">
        {formatDuration(duration)}
      </span>
    )}
    <!-- Status badges (populated by client-side script) -->
    <div class="status-badges absolute top-2 right-2 flex items-center gap-1">
      <!-- Favorite badge -->
      <div class="favorite-badge hidden items-center justify-center w-6 h-6 rounded-full" style="background-color: rgba(0,0,0,0.5);" aria-hidden="true">
        <svg class="w-3.5 h-3.5" fill="#FBBF24" stroke="#FBBF24" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
        </svg>
      </div>
      <!-- Read badge -->
      <div class="read-badge hidden items-center justify-center w-6 h-6 rounded-full" style="background-color: #10B981;" aria-hidden="true">
        <svg class="w-4 h-4" fill="none" stroke="white" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Info -->
  <div class="p-4">
    <div class="flex items-center gap-2 mb-2">
      <span class="px-2 py-0.5 rounded-full text-xs font-medium" style="background-color: var(--color-tag-bg); color: var(--color-tag-text);">
        {track}
      </span>
      <span class="px-2 py-0.5 rounded-full text-xs" style="background-color: var(--color-tag-bg); color: var(--color-tag-text);">
        {levelLabel(level)}
      </span>
    </div>
    <h3 class="font-semibold text-sm mb-1 line-clamp-2" style="color: var(--color-text-primary);">
      {titleZh}
    </h3>
    <p class="text-xs line-clamp-1" style="color: var(--color-text-tertiary);">
      {title}
    </p>
  </div>
</a>

<style>
  .favorite-badge.is-favorite,
  .read-badge.is-read {
    display: flex;
  }
</style>
