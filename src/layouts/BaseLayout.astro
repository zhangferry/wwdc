---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "WWDC Session 中文总结 — 快速了解 Apple 最新技术" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen" style="background-color: var(--color-bg); color: var(--color-text-primary);">
    <nav class="border-b" style="border-color: var(--color-border-subtle); background-color: var(--color-surface);">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <a href="/" class="text-lg font-semibold" style="color: var(--color-text-primary);">
          WWDC 中文总结
        </a>
        <a href="https://github.com/zhangferry/wwdc" target="_blank" rel="noopener noreferrer" aria-label="GitHub" style="color: var(--color-text-tertiary);">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S8.93 17.38 9 18v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
        </a>
      </div>
    </nav>
    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <slot />
    </main>
    <footer class="border-t mt-16 py-8 text-center text-sm" style="border-color: var(--color-border-subtle); color: var(--color-text-tertiary);">
      <p>内容由 AI 基于 Apple WWDC 官方字幕生成，仅供参考。</p>
      <p class="mt-1">
        数据来源：<a href="https://developer.apple.com" class="underline" style="color: var(--color-accent);">Apple Developer</a>
      </p>
    </footer>
  </body>
</html>
