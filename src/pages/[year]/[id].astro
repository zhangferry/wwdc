---
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";

export async function getStaticPaths() {
  const [s2026, s2025, s2024, s2023, s2022, s2021, s2020] = await Promise.all([
    getCollection("wwdc2026"),
    getCollection("wwdc2025"),
    getCollection("wwdc2024"),
    getCollection("wwdc2023"),
    getCollection("wwdc2022"),
    getCollection("wwdc2021"),
    getCollection("wwdc2020"),
  ]);
  const sessions = [...s2026, ...s2025, ...s2024, ...s2023, ...s2022, ...s2021, ...s2020];
  return sessions.map((session) => {
    const year = session.data.date.getFullYear();
    return {
      params: { year: `wwdc${year}`, id: session.data.id },
      props: { session },
    };
  });
}

const { session } = Astro.props;
const { Content } = await render(session);
const year = session.data.date.getFullYear();
const id = session.data.id;
---

<PostLayout
  title={session.data.title}
  titleZh={session.data.titleZh}
  track={session.data.track}
  level={session.data.level}
  duration={session.data.duration}
  date={session.data.date}
  thumbnail={session.data.thumbnail}
  videoUrl={session.data.videoUrl}
  tags={session.data.tags}
  year={year}
  id={id}
>
  <Content />
</PostLayout>
