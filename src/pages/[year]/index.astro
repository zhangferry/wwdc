---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SessionCard from "../../components/SessionCard.astro";
import FilterBar from "../../components/FilterBar.astro";
import { extractTracks } from "../../utils/format";

export function getStaticPaths() {
  return [
    { params: { year: "wwdc2026" }, props: { collection: "wwdc2026" } },
    { params: { year: "wwdc2025" }, props: { collection: "wwdc2025" } },
    { params: { year: "wwdc2024" }, props: { collection: "wwdc2024" } },
    { params: { year: "wwdc2023" }, props: { collection: "wwdc2023" } },
    { params: { year: "wwdc2022" }, props: { collection: "wwdc2022" } },
    { params: { year: "wwdc2021" }, props: { collection: "wwdc2021" } },
    { params: { year: "wwdc2020" }, props: { collection: "wwdc2020" } },
  ];
}

const { year } = Astro.params;
const { collection } = Astro.props;
const yearNum = parseInt(year.replace("wwdc", ""));

// Get all sessions for this year
const allSessions = await getCollection(collection as any);

// Sort by date descending
allSessions.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Extract unique tracks
const tracks = extractTracks(allSessions.map((s) => ({ track: s.data.track })));
---

<BaseLayout title={`WWDC ${yearNum} 中文总结`}>
  <!-- Breadcrumb -->
  <nav class="mb-6">
    <a href="/" class="text-sm hover:underline" style="color: var(--color-accent);">
      &larr; 返回首页
    </a>
  </nav>

  <!-- Hero -->
  <header class="text-center mb-10">
    <h1 class="text-3xl sm:text-4xl font-bold mb-3" style="color: var(--color-text-primary);">
      WWDC {yearNum} 中文总结
    </h1>
    <p class="text-lg" style="color: var(--color-text-secondary);">
      AI 生成的 Session 中文技术博客，5 分钟了解核心内容
    </p>
    <p class="text-sm mt-2" style="color: var(--color-text-tertiary);">
      共 {allSessions.length} 个 Session
    </p>
  </header>

  <!-- Filter -->
  <FilterBar tracks={tracks} />

  <!-- Card grid -->
  <div id="session-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
    {allSessions.map((session) => (
      <div
        class="session-card-wrapper"
        data-track={session.data.track}
        data-year={yearNum}
        data-id={session.data.id}
      >
        <SessionCard
          id={session.data.id}
          title={session.data.title}
          titleZh={session.data.titleZh}
          track={session.data.track}
          level={session.data.level}
          duration={session.data.duration}
          thumbnail={session.data.thumbnail}
          date={session.data.date}
        />
      </div>
    ))}
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="text-center py-20 hidden" style="color: var(--color-text-tertiary);">
    <p class="text-lg">暂无内容</p>
    <p class="text-sm mt-2">该分类下暂无 Session 总结</p>
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pills = document.querySelectorAll<HTMLAnchorElement>('.filter-pill');
    const cards = document.querySelectorAll<HTMLElement>('.session-card-wrapper');
    const emptyState = document.getElementById('empty-state');
    const hideReadCheckbox = document.getElementById('hide-read') as HTMLInputElement;
    const showFavoriteCheckbox = document.getElementById('show-favorite') as HTMLInputElement;

    // Initialize card states from localStorage
    cards.forEach((card) => {
      const year = card.dataset.year;
      const id = card.dataset.id;

      // Read state
      const readKey = `wwdc-read-${year}-${id}`;
      const isRead = localStorage.getItem(readKey) === '1';
      if (isRead) {
        card.setAttribute('data-read', '1');
        const readBadge = card.querySelector('.read-badge');
        if (readBadge) readBadge.classList.add('is-read');
      }

      // Favorite state
      const favKey = `wwdc-favorite-${year}-${id}`;
      const isFavorite = localStorage.getItem(favKey) === '1';
      if (isFavorite) {
        card.setAttribute('data-favorite', '1');
        const favBadge = card.querySelector('.favorite-badge');
        if (favBadge) favBadge.classList.add('is-favorite');
      }
    });

    // Apply all filters
    function applyFilters() {
      const activePill = document.querySelector('.filter-pill.filter-active');
      const track = activePill?.getAttribute('data-track') || '';
      const hideRead = hideReadCheckbox?.checked || false;
      const showFavorite = showFavoriteCheckbox?.checked || false;

      let visibleCount = 0;

      cards.forEach((card) => {
        const cardTrack = card.dataset.track;
        const isRead = card.getAttribute('data-read') === '1';
        const isFavorite = card.getAttribute('data-favorite') === '1';

        let show = true;

        // Track filter
        if (track && cardTrack !== track) {
          show = false;
        }

        // Hide read filter
        if (hideRead && isRead) {
          show = false;
        }

        // Show favorite filter
        if (showFavorite && !isFavorite) {
          show = false;
        }

        card.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      // Show/hide empty state
      if (emptyState) {
        emptyState.classList.toggle('hidden', visibleCount > 0);
      }
    }

    // Track pill click handlers
    pills.forEach(pill => {
      pill.addEventListener('click', (e) => {
        e.preventDefault();
        pills.forEach(p => p.classList.remove('filter-active'));
        pill.classList.add('filter-active');
        applyFilters();
      });
    });

    // Checkbox change handlers
    hideReadCheckbox?.addEventListener('change', applyFilters);
    showFavoriteCheckbox?.addEventListener('change', applyFilters);
  });
</script>
